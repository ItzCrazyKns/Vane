FROM node:24-alpine AS builder

# Install dependencies for building native modules if needed
RUN apk add --no-cache libc6-compat python3 make g++

WORKDIR /app

COPY package.json yarn.lock ./
RUN yarn install --frozen-lockfile --network-timeout 600000

COPY tsconfig.json next.config.mjs next-env.d.ts postcss.config.js drizzle.config.ts tailwind.config.ts ./
COPY src ./src
COPY public ./public
COPY drizzle ./drizzle

# Set environment variables for build
ENV NEXT_TELEMETRY_DISABLED=1
ENV DATA_DIR=/home/perplexica/data

RUN yarn build

# Runner stage
FROM node:24-alpine AS runner

WORKDIR /home/perplexica

# Create a non-root user
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

# Create data directory with correct permissions
RUN mkdir -p /home/perplexica/data && chown nextjs:nodejs /home/perplexica/data
RUN mkdir -p /home/perplexica/uploads && chown nextjs:nodejs /home/perplexica/uploads

COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./public/_next/static
COPY --from=builder --chown=nextjs:nodejs /app/drizzle ./drizzle

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
ENV NEXT_TELEMETRY_DISABLED=1

CMD ["node", "server.js"]
